# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=bgp_mining
POSTGRES_USER=bgp
POSTGRES_PASSWORD=changeme

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Dashboard ────────────────────────────────────────────────────────────────
# Senha de acesso ao dashboard Streamlit
DASHBOARD_PASSWORD=Acesso14

# ─── Coleta ───────────────────────────────────────────────────────────────────
# Intervalo entre ciclos completos de coleta (minutos)
COLLECTION_INTERVAL_MINUTES=60

# Delay entre requisições HTTP (segundos) para respeitar rate limits
HTTP_DELAY_SECONDS=1

# Timeout para requisições HTTP (segundos)
HTTP_TIMEOUT_SECONDS=30

# Número máximo de tentativas com backoff exponencial
MAX_RETRIES=5

# ─── Logging ──────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
